{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RunaTerminal",
  "version": "0.1.0",
  "identifier": "dev.runa.rterm",
  "build": {
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "RunaTerminal",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
